{
	"name": "Gene Function Registry",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.vscode-yaml",
				"esbenp.prettier-vscode",
				"ms-python.python"
			]
		}
	},
	"postCreateCommand": "apt-get update && apt-get install -y yq",
	"forwardPorts": [],
	"remoteUser": "vscode"
}
