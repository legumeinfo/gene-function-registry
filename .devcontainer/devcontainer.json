{
	"name": "Gene Function Registry",
	"build": {
		"dockerfile": "Dockerfile",
    "context": ".."
	},
	"features": {
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"customizations": {
		"vscode": {
      "settings": {
          "python.pythonPath": "/usr/local/bin/python",
          "python.linting.enabled": true,
          "python.linting.pylintEnabled": true,
          "python.formatting.autopep8Enabled": true,
          "editor.formatOnSave": true
      },
			"extensions": [
				"redhat.vscode-yaml",
				"esbenp.prettier-vscode",
				"ms-python.python",
        "ms-vscode.vscode-typescript-next",
        "eamodio.gitlens",
        "esbenp.prettier-vscode"
			]
		}
	},
	"forwardPorts": [],
	"remoteUser": "vscode"
  "postCreateCommand": "echo 'Dev container is ready! You can now run ./scripts/validator.sh <schema_file> <data_directory>'"
}
